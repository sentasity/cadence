# macOS
.DS_Store

# Editor swap / backup files
*.swp
*.swo
*~

# Local-only Claude Code state
.claude/local/
.claude/launch.json

# Obsidian editor config (machine-specific)
.obsidian/

# VS Code workspace settings (personal — e.g. per-repo window color)
.vscode/

# Cadence working artifacts (designs/plans) — not for the public repo
/docs/

# Cadence execution lane worktrees (auto-created/removed by /c-execute)
.cadence/worktrees/

# Astro docs site (website/) — generated, not committed
website/node_modules/
website/dist/
website/.astro/
